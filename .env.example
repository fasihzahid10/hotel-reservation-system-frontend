# --- API base (required for login / API calls) ---
#
# Option A — Remote API (e.g. Render): browser calls this URL directly. No local backend needed.
# NEXT_PUBLIC_API_URL=https://YOUR-BACKEND.onrender.com/api
#
# Option B — Local backend: use relative /api so Next.js proxies to BACKEND_PROXY_URL (see next.config.mjs).
# NEXT_PUBLIC_API_URL=/api
# Required when using /api: set to your Nest listen URL (see hotel-reservation-system-backend/.env PORT).
# BACKEND_PROXY_URL=http://127.0.0.1:4001
#
# On Render: set NEXT_PUBLIC_API_URL to your backend /api URL, then redeploy so the value is baked into the build.

COOKIE_NAME=hrs_access_token

